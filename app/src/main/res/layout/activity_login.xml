<?xml version="1.0" encoding="utf-8"?>
<!-- activity_login v5 — Modern indigo glassmorphism -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_pattern">

    <!-- Gradient overlay -->
    <View android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="@drawable/bg_login_overlay"/>

    <!-- Main content -->
    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent"
        android:scrollbars="none" android:fillViewport="true">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center"
            android:minHeight="@dimen/screen_min_height"
            android:paddingHorizontal="24dp" android:paddingVertical="60dp">

            <!-- Logo area -->
            <LinearLayout android:id="@+id/hero"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center"
                android:layout_marginBottom="40dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="80dp" android:layout_height="80dp"
                    app:cardCornerRadius="24dp"
                    app:cardBackgroundColor="#EEEEFF"
                    app:cardElevation="12dp">
                    <com.airbnb.lottie.LottieAnimationView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:lottie_fileName="anim_train.json"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true"
                        android:contentDescription="SIMO Logo"/>
                </com.google.android.material.card.MaterialCardView>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="SIMO"
                    android:textColor="@color/white"
                    android:textSize="34sp" android:textStyle="bold"
                    android:letterSpacing="0.08"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="System of Infrastructure, Maintenance &amp; Operation"
                    android:textColor="#C7D2FE"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:maxWidth="240dp"/>
            </LinearLayout>

            <!-- Form card — glassmorphism -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/formCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardBackgroundColor="#F8F9FF"
                app:cardElevation="24dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="28dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Masuk ke Akun"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp" android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Gunakan kredensial PT KAI Anda"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="24dp"/>

                    <!-- Email -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:hint="Email"
                        app:boxCornerRadiusTopStart="14dp" app:boxCornerRadiusTopEnd="14dp"
                        app:boxCornerRadiusBottomStart="14dp" app:boxCornerRadiusBottomEnd="14dp"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/primary"
                        app:startIconDrawable="@drawable/ic_user"
                        app:startIconTint="@color/text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/text_primary"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:hint="Password"
                        app:boxCornerRadiusTopStart="14dp" app:boxCornerRadiusTopEnd="14dp"
                        app:boxCornerRadiusBottomStart="14dp" app:boxCornerRadiusBottomEnd="14dp"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/primary"
                        app:startIconDrawable="@drawable/ic_role"
                        app:startIconTint="@color/text_secondary"
                        app:endIconMode="password_toggle">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textColor="@color/text_primary"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Progress -->
                    <ProgressBar android:id="@+id/progress"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:layout_marginBottom="12dp"
                        android:visibility="gone"/>

                    <!-- Login button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMasuk"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:text="Masuk"
                        android:textAllCaps="false"
                        android:textSize="16sp" android:textStyle="bold"
                        android:textColor="@color/white"
                        app:backgroundTint="@color/primary"
                        app:cornerRadius="14dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Demo credentials card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/demoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#1AFFFFFF"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#33FFFFFF">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="18dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <ImageView android:layout_width="14dp" android:layout_height="14dp"
                            android:src="@drawable/ic_role" app:tint="#A5B4FC"
                            android:contentDescription="demo" android:layout_marginEnd="6dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Demo Login — tap untuk isi otomatis"
                            android:textColor="#C7D2FE" android:textSize="11sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- CA -->
                    <LinearLayout android:id="@+id/demoCA"
                        android:layout_width="match_parent" android:layout_height="46dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:background="@drawable/bg_demo_pill"
                        android:padding="10dp" android:layout_marginBottom="6dp"
                        android:clickable="true" android:focusable="true">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Cost Accounting" android:textColor="#C7D2FE" android:textSize="9sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="ca@kai.id" android:textColor="@color/white"
                                android:textSize="11sp" android:textStyle="bold"/>
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="demo123" android:textColor="#A5B4FC" android:textSize="9sp"
                            android:fontFamily="monospace"/>
                    </LinearLayout>

                    <!-- DJKA -->
                    <LinearLayout android:id="@+id/demoDJKA"
                        android:layout_width="match_parent" android:layout_height="46dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:background="@drawable/bg_demo_pill"
                        android:padding="10dp" android:layout_marginBottom="6dp"
                        android:clickable="true" android:focusable="true">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Otoritas DJKA" android:textColor="#C7D2FE" android:textSize="9sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="djka@kai.id" android:textColor="@color/white"
                                android:textSize="11sp" android:textStyle="bold"/>
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="demo123" android:textColor="#A5B4FC" android:textSize="9sp"
                            android:fontFamily="monospace"/>
                    </LinearLayout>

                    <!-- SAP -->
                    <LinearLayout android:id="@+id/demoSAP"
                        android:layout_width="match_parent" android:layout_height="46dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:background="@drawable/bg_demo_pill"
                        android:padding="10dp"
                        android:clickable="true" android:focusable="true">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="SAP ERP" android:textColor="#C7D2FE" android:textSize="9sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="sap@kai.id" android:textColor="@color/white"
                                android:textSize="11sp" android:textStyle="bold"/>
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="demo123" android:textColor="#A5B4FC" android:textSize="9sp"
                            android:fontFamily="monospace"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
