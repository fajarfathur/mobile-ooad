<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_aktivitas v6 — Semua Aktivitas full screen clean -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header hero full width -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="@drawable/bg_header_gradient"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="13dp"
            app:cardBackgroundColor="#20FFFFFF"
            app:cardElevation="0dp"
            app:strokeColor="#25FFFFFF"
            app:strokeWidth="1dp"
            android:layout_marginEnd="14dp">
            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_verify"
                app:tint="#CCDCFF"
                android:contentDescription="aktivitas"/>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Semua Aktivitas"
                android:textColor="@color/white"
                android:textSize="22sp" android:textStyle="bold"
                android:letterSpacing="-0.01"/>
            <TextView android:id="@+id/tvAktivitasCount"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Memuat…"
                android:textColor="#99BFFF" android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Loading -->
    <ProgressBar android:id="@+id/progressAktivitas"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="32dp"
        android:visibility="gone"/>

    <!-- Empty state -->
    <LinearLayout android:id="@+id/layoutEmpty"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical" android:gravity="center"
        android:padding="40dp" android:visibility="gone">
        <com.google.android.material.card.MaterialCardView
            android:layout_width="72dp" android:layout_height="72dp"
            app:cardCornerRadius="22dp"
            app:cardBackgroundColor="@color/surface_variant"
            app:cardElevation="0dp">
            <ImageView android:layout_width="36dp" android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_verify" app:tint="@color/text_tertiary"
                android:alpha="0.5" android:contentDescription="kosong"/>
        </com.google.android.material.card.MaterialCardView>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="16dp" android:text="Belum ada aktivitas"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" android:textStyle="bold"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Aktivitas akan muncul setelah transaksi pertama"
            android:textColor="@color/text_tertiary" android:textSize="12sp"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Daftar -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSemuaAktivitas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="32dp"
        android:clipToPadding="false"/>
</LinearLayout>
