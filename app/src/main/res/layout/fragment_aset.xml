<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_aset v6 — Material You Monet, FULLY CONSISTENT header same as other fragments -->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scrollbars="none"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HERO HEADER — SAMA PERSIS seperti kontrak/biaya/billing -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/bg_header_gradient"
            android:orientation="vertical"
            android:gravity="bottom"
            android:paddingHorizontal="20dp"
            android:paddingBottom="28dp">

            <!-- Dekorasi lingkaran kanan atas -->
            <View
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:background="@drawable/bg_blob_white"
                android:alpha="0.08"
                android:layout_gravity="end"
                android:translationY="-120dp"
                android:translationX="60dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#20FFFFFF"
                app:cardElevation="0dp"
                app:strokeColor="#25FFFFFF"
                app:strokeWidth="1dp"
                android:layout_marginBottom="14dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_sync"
                    app:tint="#CCDCFF"
                    android:contentDescription="aset"/>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Data Aset Infrastruktur"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="UC-22 · Dikelola SAP ERP"
                android:textColor="#99BFFF"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- STAT CARDS ROW — floating keluar dari header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="-28dp"
            android:clipToPadding="false">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/surface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:id="@+id/tvTotalAset"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/primary"
                        android:textSize="24sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Total Aset" android:textColor="@color/text_secondary" android:textSize="10sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="5dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/surface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:id="@+id/tvAsetAktif"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/success"
                        android:textSize="24sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Aktif" android:textColor="@color/text_secondary" android:textSize="10sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/surface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:id="@+id/tvAsetRusak"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/warning"
                        android:textSize="24sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Perlu Perbaikan" android:textColor="@color/text_secondary" android:textSize="10sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- INFO CHIP revisi -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/card_amber_soft">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                <View android:layout_width="8dp" android:layout_height="8dp"
                    android:background="@drawable/bg_dot_amber"
                    android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Revisi OOAD: Hak kelola dipindahkan ke aktor SAP ERP"
                    android:textColor="@color/warning"
                    android:textSize="11sp" android:textStyle="bold"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- TOMBOL SINKRONISASI -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSinkronSap"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="14dp"
            android:text="Sinkronisasi Aset dari SAP ERP"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:backgroundTint="@color/primary"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_sync"
            app:iconTint="@color/white"
            app:iconSize="18dp"
            app:iconPadding="8dp"/>

        <!-- TAMBAH ASET button (outline) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTambahAset"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:text="+ Tambah Aset Infrastruktur"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            app:cornerRadius="16dp"
            app:strokeColor="@color/primary"
            app:strokeWidth="1.5dp"/>

        <!-- STATUS SYNC result -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStatusSyncAset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/card_blue_soft"
            android:visibility="gone">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                <View android:layout_width="8dp" android:layout_height="8dp"
                    android:background="@drawable/bg_dot_indigo"
                    android:layout_marginEnd="10dp"/>
                <TextView android:id="@+id/tvStatusSync"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Sinkronisasi selesai"
                    android:textColor="@color/primary"
                    android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- DAFTAR ASET card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/divider"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="18dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="36dp" android:layout_height="36dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="@color/primary_50" app:cardElevation="0dp">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_contract"
                            app:tint="@color/primary"
                            android:contentDescription="list"/>
                    </com.google.android.material.card.MaterialCardView>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="12dp"
                        android:text="Inventaris Aset PT KAI"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" android:textStyle="bold"/>
                </LinearLayout>

                <ProgressBar android:id="@+id/progressAset"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center" android:visibility="gone"/>

                <TextView android:id="@+id/tvAsetList"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary" android:textSize="13sp"
                    android:lineSpacingExtra="8dp"
                    android:text="Memuat data aset…"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- INFO AKTOR pill -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/primary_50">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                <ImageView android:layout_width="14dp" android:layout_height="14dp"
                    android:src="@drawable/ic_role" app:tint="@color/primary"
                    android:layout_marginEnd="8dp" android:contentDescription="aktor"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SAP ERP (kelola) · Cost Accounting (baca) — UC-22"
                    android:textSize="11sp" android:textColor="@color/primary"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
