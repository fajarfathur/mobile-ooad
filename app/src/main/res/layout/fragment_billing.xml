<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_billing v6 — Monet consistent header + clean cards -->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scrollbars="none"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HERO HEADER konsisten -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/bg_header_gradient"
            android:orientation="vertical"
            android:gravity="bottom"
            android:paddingHorizontal="20dp"
            android:paddingBottom="28dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#20FFFFFF"
                app:cardElevation="0dp"
                app:strokeColor="#25FFFFFF"
                app:strokeWidth="1dp"
                android:layout_marginBottom="14dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_billing"
                    app:tint="#CCDCFF"
                    android:contentDescription="billing"/>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Billing &amp; Tagihan"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02"/>
            <TextView android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="UC-24 · UC-25 · UC-26 — DJKA"
                android:textColor="#99BFFF"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- STAT CARDS floating -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="-28dp"
            android:clipToPadding="false">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="5dp"
                app:cardCornerRadius="18dp" app:cardElevation="8dp"
                app:cardBackgroundColor="@color/surface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:id="@+id/tvVerifiedCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="2" android:textColor="@color/success"
                        android:textSize="24sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Diverifikasi" android:textColor="@color/text_secondary" android:textSize="10sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginHorizontal="5dp"
                app:cardCornerRadius="18dp" app:cardElevation="8dp"
                app:cardBackgroundColor="@color/surface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:id="@+id/tvSentCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="1" android:textColor="@color/primary"
                        android:textSize="24sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Terbit" android:textColor="@color/text_secondary" android:textSize="10sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="5dp"
                app:cardCornerRadius="18dp" app:cardElevation="8dp"
                app:cardBackgroundColor="@color/surface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:id="@+id/tvDraftCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="1" android:textColor="@color/warning"
                        android:textSize="24sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Draft" android:textColor="@color/text_secondary" android:textSize="10sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- GENERATE BILLING card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/sectionGenerate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/divider"
            app:cardBackgroundColor="@color/surface">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="36dp" android:layout_height="36dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="@color/card_amber_soft" app:cardElevation="0dp">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_billing"
                            app:tint="@color/warning"
                            android:contentDescription="generate"/>
                    </com.google.android.material.card.MaterialCardView>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="12dp"
                        android:text="Generate Billing ke DJKA"
                        android:textSize="15sp" android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:letterSpacing="-0.01"/>
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGenerate"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Generate Tagihan Baru"
                    android:textAllCaps="false" android:textStyle="bold"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/warning"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_billing"
                    app:iconTint="@color/white"
                    app:iconSize="18dp"
                    app:iconPadding="8dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- VERIFIKASI / REVISI buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="10dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerifikasi"
                android:layout_width="0dp" android:layout_height="52dp"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                android:text="✓  Verifikasi"
                android:textAllCaps="false" android:textStyle="bold"
                android:textColor="@color/white"
                app:backgroundTint="@color/success" app:cornerRadius="16dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRevisi"
                android:layout_width="0dp" android:layout_height="52dp"
                android:layout_weight="1" android:layout_marginStart="6dp"
                android:text="Kembalikan"
                android:textAllCaps="false" android:textStyle="bold"
                android:textColor="@color/white"
                app:backgroundTint="@color/warning" app:cornerRadius="16dp"/>
        </LinearLayout>

        <!-- STATUS FEEDBACK card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="10dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/primary_50">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                <View android:layout_width="8dp" android:layout_height="8dp"
                    android:background="@drawable/bg_dot_green"
                    android:layout_marginEnd="10dp"/>
                <TextView android:id="@+id/tvStatusBilling"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textColor="@color/primary"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- RIWAYAT TAGIHAN -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/divider"
            app:cardBackgroundColor="@color/surface">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="36dp" android:layout_height="36dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="@color/primary_50" app:cardElevation="0dp">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_billing"
                            app:tint="@color/primary"
                            android:contentDescription="riwayat"/>
                    </com.google.android.material.card.MaterialCardView>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="12dp"
                        android:text="Riwayat Tagihan"
                        android:textSize="14sp" android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:letterSpacing="-0.01"/>
                </LinearLayout>
                <ProgressBar android:id="@+id/progressTagihan"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center" android:visibility="gone"/>
                <TextView android:id="@+id/tvTagihanList"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary" android:textSize="13sp"
                    android:lineSpacingExtra="8dp"
                    android:text="Memuat data tagihan…"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- INFO AKTOR -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/card_amber_soft">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                <ImageView android:layout_width="14dp" android:layout_height="14dp"
                    android:src="@drawable/ic_role" app:tint="@color/warning"
                    android:layout_marginEnd="8dp" android:contentDescription="aktor"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Aktor: Cost Accounting · DJKA — UC-24 · UC-25 · UC-26"
                    android:textSize="11sp" android:textColor="@color/warning"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
