<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_dashboard v6 — Material You, Monet clean, Android 16 style -->
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:background="@color/background"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HERO HEADER ===== -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@drawable/bg_header_gradient"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- Lingkaran dekorasi kanan atas -->
                <View
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="-70dp"
                    android:layout_marginEnd="-70dp"
                    android:background="@drawable/bg_blob_white"
                    android:alpha="0.10"/>

                <!-- Lingkaran dekorasi kiri bawah -->
                <View
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_alignParentBottom="true"
                    android:layout_marginStart="-30dp"
                    android:layout_marginBottom="-30dp"
                    android:background="@drawable/bg_blob_white"
                    android:alpha="0.07"/>

                <!-- Greeting + Lottie -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="52dp"
                    android:paddingHorizontal="20dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Selamat datang,"
                            android:textColor="#99BFFF"
                            android:textSize="13sp"
                            android:letterSpacing="0.01"/>

                        <TextView
                            android:id="@+id/tvGreeting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Pengguna"
                            android:textColor="@color/white"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:letterSpacing="-0.01"/>

                        <!-- Chip role -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="24dp"
                            android:layout_marginTop="10dp"
                            app:cardCornerRadius="12dp"
                            app:cardBackgroundColor="#1EFFFFFF"
                            app:cardElevation="0dp"
                            app:strokeColor="#33FFFFFF"
                            app:strokeWidth="1dp">
                            <TextView
                                android:id="@+id/tvRole"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:paddingHorizontal="12dp"
                                android:text="—"
                                android:textColor="#DDEBFF"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.02"/>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <!-- Lottie kereta -->
                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/lottieHero"
                        android:layout_width="96dp"
                        android:layout_height="80dp"
                        app:lottie_fileName="anim_train.json"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true"
                        android:contentDescription="Train animation"/>
                </LinearLayout>
            </RelativeLayout>

            <!-- ===== STAT CARDS — floating, tonal style ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:layout_marginTop="-30dp"
                android:clipToPadding="false">

                <!-- Kontrak -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardKontrak"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="@color/surface"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <!-- Icon tonal -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            app:cardCornerRadius="12dp"
                            app:cardBackgroundColor="@color/card_blue_soft"
                            app:cardElevation="0dp">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_contract"
                                app:tint="@color/card_blue"
                                android:contentDescription="kontrak"/>
                        </com.google.android.material.card.MaterialCardView>
                        <TextView
                            android:id="@+id/tvKontrakValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="—"
                            android:textColor="@color/text_primary"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.02"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Kontrak"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Biaya -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardBiaya"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="5dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="@color/surface"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            app:cardCornerRadius="12dp"
                            app:cardBackgroundColor="@color/card_green_soft"
                            app:cardElevation="0dp">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_cost"
                                app:tint="@color/card_green"
                                android:contentDescription="biaya"/>
                        </com.google.android.material.card.MaterialCardView>
                        <TextView
                            android:id="@+id/tvBiayaValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="—"
                            android:textColor="@color/text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.02"
                            android:maxLines="1"
                            android:ellipsize="end"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Total Biaya"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Tagihan -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTagihan"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="@color/surface"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            app:cardCornerRadius="12dp"
                            app:cardBackgroundColor="@color/card_amber_soft"
                            app:cardElevation="0dp">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_billing"
                                app:tint="@color/card_amber"
                                android:contentDescription="tagihan"/>
                        </com.google.android.material.card.MaterialCardView>
                        <TextView
                            android:id="@+id/tvTagihanValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="—"
                            android:textColor="@color/text_primary"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.02"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Tagihan"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ===== CHART TREN ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tren Biaya IMO"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:letterSpacing="-0.01"/>
                            <TextView
                                android:id="@+id/tvChartSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Ketuk bar untuk detail · 2024"
                                android:textColor="@color/text_tertiary"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <!-- Chip "Live" -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="26dp"
                            app:cardCornerRadius="13dp"
                            app:cardBackgroundColor="@color/card_blue_soft"
                            app:cardElevation="0dp">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:orientation="horizontal"
                                android:gravity="center"
                                android:paddingHorizontal="10dp">
                                <View
                                    android:layout_width="6dp"
                                    android:layout_height="6dp"
                                    android:background="@drawable/bg_dot_indigo"
                                    android:layout_marginEnd="5dp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Realtime"
                                    android:textColor="@color/primary"
                                    android:textSize="10sp"
                                    android:textStyle="bold"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <com.kelompok1.simo.ui.widget.QuarterlyChartView
                        android:id="@+id/chartView"
                        android:layout_width="match_parent"
                        android:layout_height="190dp"
                        android:layout_marginTop="4dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/tvChartTapInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Tap batang untuk melihat detail"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== MENU CEPAT — 3 kolom tonal ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Menu Cepat"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.01"
                        android:layout_marginBottom="14dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Kontrak QA -->
                        <LinearLayout
                            android:id="@+id/qaKontrak"
                            android:layout_width="0dp"
                            android:layout_height="80dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/bg_qa_indigo"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_contract"
                                app:tint="@color/primary"
                                android:contentDescription="kontrak"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="7dp"
                                android:text="Kontrak"
                                android:textColor="@color/primary"
                                android:textSize="11sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <!-- Biaya QA -->
                        <LinearLayout
                            android:id="@+id/qaBiaya"
                            android:layout_width="0dp"
                            android:layout_height="80dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="3dp"
                            android:background="@drawable/bg_qa_green"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_cost"
                                app:tint="@color/accent_green"
                                android:contentDescription="biaya"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="7dp"
                                android:text="Biaya"
                                android:textColor="@color/accent_green"
                                android:textSize="11sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <!-- Billing QA -->
                        <LinearLayout
                            android:id="@+id/qaBilling"
                            android:layout_width="0dp"
                            android:layout_height="80dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/bg_qa_amber"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_billing"
                                app:tint="@color/accent_amber"
                                android:contentDescription="billing"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="7dp"
                                android:text="Billing"
                                android:textColor="@color/accent_amber"
                                android:textSize="11sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== AKTIVITAS TERBARU ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Aktivitas Terbaru"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.01"/>

                <TextView
                    android:id="@+id/tvLihatSemua"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lihat semua"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingVertical="8dp"
                    android:paddingHorizontal="4dp"
                    android:background="?attr/selectableItemBackground"/>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginVertical="16dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="24dp"
                android:text="Belum ada aktivitas"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAktivitas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingBottom="40dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
