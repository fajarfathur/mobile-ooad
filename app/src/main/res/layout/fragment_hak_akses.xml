<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_hak_akses v6 — Monet consistent header -->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scrollbars="none"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HERO HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/bg_header_gradient"
            android:orientation="vertical"
            android:gravity="bottom"
            android:paddingHorizontal="20dp"
            android:paddingBottom="28dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#20FFFFFF"
                app:cardElevation="0dp"
                app:strokeColor="#25FFFFFF"
                app:strokeWidth="1dp"
                android:layout_marginBottom="14dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_role"
                    app:tint="#CCDCFF"
                    android:contentDescription="role"/>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hak Akses &amp; Role"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="UC-02 · Dikelola Cost Accounting"
                android:textColor="#99BFFF"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- STAT CARDS floating -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="-28dp"
            android:clipToPadding="false">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="5dp"
                app:cardCornerRadius="18dp" app:cardElevation="8dp"
                app:cardBackgroundColor="@color/surface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:id="@+id/tvUserCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/primary"
                        android:textSize="24sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Pengguna" android:textColor="@color/text_secondary" android:textSize="10sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="5dp"
                app:cardCornerRadius="18dp" app:cardElevation="8dp"
                app:cardBackgroundColor="@color/surface">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:id="@+id/tvRoleCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="3" android:textColor="@color/secondary"
                        android:textSize="24sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Role Aktif" android:textColor="@color/text_secondary" android:textSize="10sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Revisi info chip -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/card_green_soft">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                <View android:layout_width="8dp" android:layout_height="8dp"
                    android:background="@drawable/bg_dot_green"
                    android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Revisi UCD 4.1: Aktor IT Support dihapus dari sistem SIMO"
                    android:textColor="@color/success"
                    android:textSize="11sp" android:textStyle="bold"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- AKSI BUTTONS -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="14dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTambahUser"
                android:layout_width="0dp" android:layout_height="52dp"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                android:text="+ Tambah User"
                android:textAllCaps="false" android:textStyle="bold"
                android:textColor="@color/white"
                app:backgroundTint="@color/primary" app:cornerRadius="16dp"
                app:icon="@drawable/ic_user" app:iconTint="@color/white" app:iconSize="16dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnKelolRole"
                android:layout_width="0dp" android:layout_height="52dp"
                android:layout_weight="1" android:layout_marginStart="6dp"
                android:text="Kelola Role"
                android:textAllCaps="false" android:textStyle="bold"
                android:textColor="@color/white"
                app:backgroundTint="@color/secondary" app:cornerRadius="16dp"
                app:icon="@drawable/ic_role" app:iconTint="@color/white" app:iconSize="16dp"/>
        </LinearLayout>

        <!-- STATUS AKSI card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStatusAksi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="10dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:cardBackgroundColor="@color/primary_50">
            <TextView android:id="@+id/tvStatusAksi"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:padding="14dp" android:textSize="13sp"
                android:textColor="@color/primary"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- DAFTAR PENGGUNA -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="20dp" app:cardElevation="0dp"
            app:strokeWidth="1dp" app:strokeColor="@color/divider"
            app:cardBackgroundColor="@color/surface">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="36dp" android:layout_height="36dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="@color/primary_50" app:cardElevation="0dp">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_user" app:tint="@color/primary"
                            android:contentDescription="users"/>
                    </com.google.android.material.card.MaterialCardView>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="12dp"
                        android:text="Daftar Pengguna"
                        android:textSize="14sp" android:textStyle="bold"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>
                <ProgressBar android:id="@+id/progressUsers"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center" android:visibility="gone"/>
                <TextView android:id="@+id/tvUserList"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary" android:textSize="13sp"
                    android:lineSpacingExtra="8dp" android:text="Memuat data…"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- DAFTAR ROLE -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="20dp" app:cardElevation="0dp"
            app:strokeWidth="1dp" app:strokeColor="@color/divider"
            app:cardBackgroundColor="@color/surface">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="36dp" android:layout_height="36dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="@color/secondary_50" app:cardElevation="0dp">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_role" app:tint="@color/secondary"
                            android:contentDescription="roles"/>
                    </com.google.android.material.card.MaterialCardView>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="12dp"
                        android:text="3 Aktor Role SIMO"
                        android:textSize="14sp" android:textStyle="bold"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>
                <TextView android:id="@+id/tvRoleList"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" android:lineSpacingExtra="8dp"
                    android:text="Memuat data…"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
