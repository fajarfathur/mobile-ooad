<?xml version="1.0" encoding="utf-8"?>
<!-- item_aktivitas v6 — clean row, no card border, full ripple -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="12dp"
    android:paddingHorizontal="4dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground">

    <!-- Icon tonal badge -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardBadge"
        android:layout_width="42dp"
        android:layout_height="42dp"
        app:cardCornerRadius="13dp"
        app:cardBackgroundColor="@color/primary_50"
        app:cardElevation="0dp">
        <ImageView
            android:id="@+id/ivBadge"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_contract"
            app:tint="@color/primary"
            android:contentDescription="aktivitas"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- Teks info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="13dp">

        <TextView
            android:id="@+id/tvJudul"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:letterSpacing="-0.005"/>

        <TextView
            android:id="@+id/tvWaktu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="—"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- Arrow -->
    <ImageView
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_dashboard"
        app:tint="@color/text_tertiary"
        android:layout_marginStart="10dp"
        android:rotation="-90"
        android:contentDescription="detail"
        android:alpha="0.6"/>
</LinearLayout>
